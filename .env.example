# Шаблон файла .env для WG Easy Bot
# Скопируйте этот файл в .env и заполните значениями

# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# URL панели WG Easy (для Docker используйте http://wg-easy:51821)
WG_EASY_URL=http://localhost:51821

# Пароль от панели WG Easy
WG_EASY_PASSWORD=your_wg_easy_password

# ID Telegram администраторов (через запятую, без пробелов)
# Узнайте свой ID через @userinfobot
ADMIN_IDS=123456789

# Включить режим продажи (true/false)
SALE_ENABLED=false

# Способы оплаты (поддерживаются переносы строк \n)
PAYMENT_METHODS=Карта: 1234 5678 9012 3456\nСБП: +7 999 123 45 67
